# raven-memory — gitignore

# Database files — never commit, may contain sensitive memories
*.db
*.db-shm
*.db-wal

# API keys and env files
.env
.env.*
*.key

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Testing artifacts
.pytest_cache/
htmlcov/
.coverage
*.log

# OS
.DS_Store
Thumbs.db
